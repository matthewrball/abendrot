{
  "$schema": "https://design-tokens.org/format",
  "meta": {
    "name": "Abendrot Design Tokens",
    "status": "WORKING direction (2026-06-17) — sunset palette pulled from assets/abendrot.png (the app icon). May change; keep as tokens.",
    "version": "0.2.0-icon",
    "date": "2026-06-17",
    "rules": [
      "Never pure #000 — grounds are warm-tinted near-blacks from the icon sky.",
      "reveal-true-white (#FFFFFF) is RESERVED for the Reveal-True-Color moment only.",
      "Warmth is the default state; Light + Reduce-Transparency surfaces are warm cream/oxblood, never neutral grey.",
      "Consumed by the app (mirror into Swift Color/asset catalog) and the web surfaces."
    ]
  },
  "color": {
    "accent": {
      "base":      { "value": "#FD9228", "rgb": [253, 146, 40], "desc": "primary — golden sun core" },
      "highlight": { "value": "#FFC061", "rgb": [255, 192, 97], "desc": "highlight / gradient top" },
      "deep":      { "value": "#C2310A", "rgb": [194, 49, 10],  "desc": "deep ember-orange / gradient base" },
      "hi":        { "value": "#FFE0B8", "rgb": [255, 224, 184], "desc": "faintest warm rim light" },
      "press":     { "value": "#E2740F", "rgb": [226, 116, 15], "desc": "pressed / active accent" },
      "ink-on-cream": { "value": "#9C4310", "desc": "ember text on cream, AA-normal (>=4.5:1)" }
    },
    "ground": {
      "indigo":     { "value": "#160A12", "desc": "deepest warm near-black sky (never #000)" },
      "plum":       { "value": "#221019", "desc": "deep oxblood-brown" },
      "twilight":   { "value": "#341320", "desc": "raised oxblood surface" },
      "twilight-2": { "value": "#45192A", "desc": "hover / elevated surface" }
    },
    "text": {
      "primary": { "value": "#F3EADF", "desc": "warm off-white (NOT #fff)" },
      "muted":   { "value": "rgba(243,234,223,0.60)" },
      "faint":   { "value": "rgba(243,234,223,0.38)" },
      "cream":   { "value": "#F7ECD9", "desc": "warm light accent text / hero numerals / knobs" }
    },
    "reserved": {
      "reveal-true-white": { "value": "#FFFFFF", "desc": "RESERVED for Reveal-True-Color veil only — do not reuse" }
    },
    "line": {
      "base":   { "value": "rgba(255,240,230,0.10)" },
      "strong": { "value": "rgba(255,240,230,0.16)" }
    },
    "signature-sunset": {
      "value": "linear-gradient(180deg, #160A12 0%, #2A0F16 34%, #6A100F 60%, #C2310A 80%, #FB7C0E 92%, #FD9228 100%)",
      "desc": "the icon's vertical sky->sun ramp; the brand's hero gradient"
    },
    "light": {
      "ground": {
        "indigo":     { "value": "#F0E2D0", "desc": "warm cream-sand deepest ground" },
        "plum":       { "value": "#F5E9D8" },
        "twilight":   { "value": "#FBF1E4" },
        "twilight-2": { "value": "#FFF7EC" }
      },
      "text": {
        "primary": { "value": "#2E1A1A", "desc": "deep ember-ink (NOT pure black)" },
        "muted":   { "value": "rgba(46,26,26,0.62)" },
        "faint":   { "value": "rgba(46,26,26,0.40)" }
      },
      "accent": {
        "deep": { "value": "#B0430F", "desc": "deeper ember for AA contrast on cream" }
      },
      "line": {
        "base":   { "value": "rgba(46,26,26,0.12)" },
        "strong": { "value": "rgba(46,26,26,0.20)" }
      }
    }
  },
  "material": {
    "glass": {
      "blur":      { "value": "16px" },
      "saturate":  { "value": "190%" },
      "tint":      { "value": "linear-gradient(140deg, rgba(255,255,255,0.11) 0%, rgba(255,255,255,0.035) 46%, rgba(255,255,255,0.06) 100%)" },
      "inset-top": { "value": "inset 0 1px 1.5px rgba(255,255,255,0.65)", "desc": "double inset highlight — top" },
      "inset-edge":{ "value": "inset 0 0 0 0.5px rgba(255,255,255,0.30)", "desc": "double inset highlight — edge" },
      "outer":     { "value": "0 16px 40px rgba(0,0,0,0.45)" }
    },
    "frost": {
      "desc":      "more-opaque 'frosted ember' material for Settings / data-heavy chrome",
      "blur":      { "value": "30px" },
      "saturate":  { "value": "160%" },
      "tint":      { "value": "linear-gradient(150deg, rgba(58,21,33,0.86) 0%, rgba(36,16,25,0.92) 100%)" }
    },
    "glow": {
      "accent":      { "value": "0 0 24px -6px rgba(253,146,40,0.9)" },
      "accent-soft": { "value": "0 0 36px -10px rgba(253,146,40,0.7)" }
    },
    "reduce-transparency": {
      "desc":       "SOLID fallback — ember-tinted, NEVER neutral grey",
      "dark-tint":  { "value": "linear-gradient(150deg, #2B1019 0%, #1E0B12 100%)" },
      "light-tint": { "value": "linear-gradient(150deg, #FBF1E4 0%, #F4E8D7 100%)" }
    }
  },
  "radius": {
    "card":    { "value": "22px" },
    "control": { "value": "12px" },
    "pill":    { "value": "999px" }
  },
  "motion": {
    "ease-warm":     { "value": "cubic-bezier(0.22, 0.61, 0.36, 1)", "desc": "signature warmth ease" },
    "ease-standard": { "value": "cubic-bezier(0.4, 0, 0.2, 1)" },
    "dur-fast":      { "value": "110ms" },
    "dur-base":      { "value": "140ms" },
    "dur-reveal":    { "value": "220ms", "desc": "lift-the-veil; spring (.interactiveSpring) in-app" }
  },
  "type": {
    "serif":     { "value": "ui-serif, \"New York\", \"Iowan Old Style\", Georgia, serif", "use": "wordmark + hero Kelvin numerals" },
    "ui":        { "value": "-apple-system, \"SF Pro Text\", BlinkMacSystemFont, system-ui, sans-serif", "use": "all UI chrome" },
    "marketing": { "value": "\"Figtree\", -apple-system, sans-serif", "use": "optional humanist sans for landing" }
  }
}
