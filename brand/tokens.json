{
  "$schema": "https://design-tokens.org/format",
  "meta": {
    "name": "Abendrot Design Tokens",
    "status": "PROVISIONAL — refine per plan §5.5; founder selects final accent + icon before lock",
    "version": "0.1.0-provisional",
    "date": "2026-06-16",
    "rules": [
      "Never pure #000 — grounds are warm-tinted near-blacks.",
      "reveal-true-white (#FFFFFF) is RESERVED for the Reveal-True-Color moment only.",
      "Warmth is the default state; Light + Reduce-Transparency surfaces are warm cream/twilight, never neutral grey.",
      "Consumed by Lane B (app: mirror into Swift Color/asset catalog) and Lane D (landing)."
    ]
  },
  "color": {
    "accent": {
      "base":      { "value": "#FFAB5C", "rgb": [255, 171, 92],  "desc": "primary ember amber" },
      "highlight": { "value": "#FFD6A3", "rgb": [255, 214, 163], "desc": "highlight / gradient top" },
      "deep":      { "value": "#C2591F", "rgb": [194, 89, 31],   "desc": "deep ember / gradient base" },
      "hi":        { "value": "#FFE7CC", "rgb": [255, 231, 204], "desc": "faintest warm rim light" },
      "press":     { "value": "#E8924A", "rgb": [232, 146, 74],  "desc": "pressed / active accent" }
    },
    "ground": {
      "indigo":     { "value": "#0C0A16", "desc": "deepest twilight ground (never #000)" },
      "plum":       { "value": "#171029", "desc": "mid twilight" },
      "twilight":   { "value": "#1D1533", "desc": "raised surfaces" },
      "twilight-2": { "value": "#261B40", "desc": "hover / elevated surface" }
    },
    "text": {
      "primary": { "value": "#ECE8F4", "desc": "warm off-white (NOT #fff)" },
      "muted":   { "value": "rgba(236,232,244,0.60)" },
      "faint":   { "value": "rgba(236,232,244,0.38)" },
      "cream":   { "value": "#F7ECD9", "desc": "warm light accent text / hero numerals" }
    },
    "reserved": {
      "reveal-true-white": { "value": "#FFFFFF", "desc": "RESERVED for Reveal-True-Color veil only — do not reuse" }
    },
    "line": {
      "base":   { "value": "rgba(255,255,255,0.10)" },
      "strong": { "value": "rgba(255,255,255,0.16)" }
    },
    "light": {
      "ground": {
        "indigo":     { "value": "#EFE4D2", "desc": "warm cream-sand deepest ground" },
        "plum":       { "value": "#F4EADB" },
        "twilight":   { "value": "#FAF2E6" },
        "twilight-2": { "value": "#FFF8EE" }
      },
      "text": {
        "primary": { "value": "#2A2036", "desc": "deep plum-ink (NOT pure black)" },
        "muted":   { "value": "rgba(42,32,54,0.62)" },
        "faint":   { "value": "rgba(42,32,54,0.40)" }
      },
      "accent": {
        "deep": { "value": "#B14E18", "desc": "deeper ember for AA contrast on cream" }
      },
      "line": {
        "base":   { "value": "rgba(42,32,54,0.12)" },
        "strong": { "value": "rgba(42,32,54,0.20)" }
      }
    }
  },
  "material": {
    "glass": {
      "blur":      { "value": "16px" },
      "saturate":  { "value": "190%" },
      "tint":      { "value": "linear-gradient(140deg, rgba(255,255,255,0.11) 0%, rgba(255,255,255,0.035) 46%, rgba(255,255,255,0.06) 100%)" },
      "inset-top": { "value": "inset 0 1px 1.5px rgba(255,255,255,0.65)", "desc": "double inset highlight — top" },
      "inset-edge":{ "value": "inset 0 0 0 0.5px rgba(255,255,255,0.30)", "desc": "double inset highlight — edge" },
      "outer":     { "value": "0 16px 40px rgba(0,0,0,0.45)" }
    },
    "frost": {
      "desc":      "more-opaque 'frosted ember' material for Settings / data-heavy chrome",
      "blur":      { "value": "30px" },
      "saturate":  { "value": "160%" },
      "tint":      { "value": "linear-gradient(150deg, rgba(43,30,64,0.86) 0%, rgba(28,20,46,0.92) 100%)" }
    },
    "glow": {
      "accent":      { "value": "0 0 24px -6px rgba(255,171,92,0.9)" },
      "accent-soft": { "value": "0 0 36px -10px rgba(255,171,92,0.7)" }
    },
    "reduce-transparency": {
      "desc":       "SOLID fallback — ember-tinted, NEVER neutral grey",
      "dark-tint":  { "value": "linear-gradient(150deg, #251A3C 0%, #1B1430 100%)" },
      "light-tint": { "value": "linear-gradient(150deg, #FBF3E7 0%, #F4EADB 100%)" }
    }
  },
  "radius": {
    "card":    { "value": "22px" },
    "control": { "value": "12px" },
    "pill":    { "value": "999px" }
  },
  "motion": {
    "ease-warm":     { "value": "cubic-bezier(0.22, 0.61, 0.36, 1)", "desc": "signature warmth ease" },
    "ease-standard": { "value": "cubic-bezier(0.4, 0, 0.2, 1)" },
    "dur-fast":      { "value": "110ms" },
    "dur-base":      { "value": "140ms" },
    "dur-reveal":    { "value": "220ms", "desc": "lift-the-veil; spring (.interactiveSpring) in-app" }
  },
  "type": {
    "serif":     { "value": "ui-serif, \"New York\", \"Iowan Old Style\", Georgia, serif", "use": "wordmark + hero Kelvin numerals" },
    "ui":        { "value": "-apple-system, \"SF Pro Text\", BlinkMacSystemFont, system-ui, sans-serif", "use": "all UI chrome" },
    "marketing": { "value": "\"Figtree\", -apple-system, sans-serif", "use": "optional humanist sans for landing" }
  }
}
