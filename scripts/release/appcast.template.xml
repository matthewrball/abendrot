<?xml version="1.0" encoding="utf-8"?>
<!--
  Abendrot Sparkle appcast TEMPLATE.

  release.sh copies this to /appcast.xml on first release, then PREPENDS each new
  <item> directly below the anchor comment at the top of <channel> (just under
  <language>), preserving all prior entries (Sparkle clients dedupe by the
  <sparkle:version> element build number).

  HOSTING: the appcast + binaries live on GitHub. Sparkle's
  SUFeedURL in Info.plist points at the RAW GitHub URL of this file on the default
  branch, e.g.:
    https://raw.githubusercontent.com/matthewrball/abendrot/main/appcast.xml
  The app must set SUFeedURL + SUPublicEDKey in the app's Info.plist accordingly.

  Each SIGNED <item>'s sparkle:edSignature is produced by Sparkle's `sign_update`
  using the SINGLE release authority's EdDSA private key (login keychain only —
  never committed). release.sh HARD-FAILS rather than emit a signed item with an
  empty signature, so a signature attribute here is always a real signature.

  UNSIGNED items (release.sh --unsigned) OMIT the sparkle:edSignature
  attribute ENTIRELY (never an empty string) and carry "(UNSIGNED build)" in
  the title. Sparkle with SUPublicEDKey configured rejects an unsigned enclosure,
  so such items must NOT be published to a real auto-update channel.
-->
<rss version="2.0"
     xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>Abendrot</title>
    <link>https://raw.githubusercontent.com/matthewrball/abendrot/main/appcast.xml</link>
    <description>Most recent changes for Abendrot — circadian screen warmth for macOS.</description>
    <language>en</language>
    <!-- release.sh inserts new <item> elements directly below this line. -->
  </channel>
</rss>
